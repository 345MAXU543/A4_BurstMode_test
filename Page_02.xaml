<Page x:Class="A4_BurstMode_test.Page_02"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:A4_BurstMode_test"
      mc:Ignorable="d" 
      d:DesignHeight="970" d:DesignWidth="1500"
      Title="Page_02">

    <Grid Background="#FF0C400A">
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Border Grid.Row="0" Opacity="1" HorizontalAlignment="Left" Width="600">
            <Border.Background>
                <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                    <LinearGradientBrush.RelativeTransform>
                        <TransformGroup>
                            <ScaleTransform CenterY="0.5" CenterX="0.5"/>
                            <SkewTransform CenterX="0.5" CenterY="0.5"/>
                            <RotateTransform Angle="-90" CenterX="0.5" CenterY="0.5"/>
                            <TranslateTransform/>
                        </TransformGroup>
                    </LinearGradientBrush.RelativeTransform>
                    <GradientStop Color="#FF09B903" Offset="0.348"/>
                    <GradientStop Color="#FF0C400A" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <Label Content="  Encoder tester  " HorizontalAlignment="Left" VerticalAlignment="Top" Padding="0,0,0,0" FontSize="40" Foreground="White" />
        </Border>

        <Canvas Grid.Row="1">
            <Label Content="ENC1" Canvas.Left="131" Canvas.Top="50" FontSize="60" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" Height="86"/>
            <Label Content="ENC2" Canvas.Left="131" Canvas.Top="150" FontSize="60" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" Height="86" Width="166"/>
            <Label Content="ENC3" Canvas.Left="131" Canvas.Top="250" FontSize="60" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" Height="86" Width="166"/>
            <Label Content="ENC4" Canvas.Left="131" Canvas.Top="350" FontSize="60" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" Height="86" Width="166"/>
            <TextBox Name="txt_enc1" Canvas.Left="330" TextWrapping="Wrap" FontSize="30" Text="TextBox" Canvas.Top="70" Width="300" HorizontalAlignment="Left" VerticalAlignment="Top" Height="48"/>
            <TextBox Name="txt_enc2" Canvas.Left="330" TextWrapping="Wrap" FontSize="30" Text="TextBox" Canvas.Top="170" Width="300" Height="48" HorizontalAlignment="Left" VerticalAlignment="Top"/>
            <TextBox Name="txt_enc3" Canvas.Left="330" TextWrapping="Wrap" FontSize="30" Text="TextBox" Canvas.Top="270" Width="300" HorizontalAlignment="Left" VerticalAlignment="Top" Height="48"/>
            <TextBox Name="txt_enc4" Canvas.Left="330" TextWrapping="Wrap" FontSize="30" Text="TextBox" Canvas.Top="370" Width="300" Height="48" HorizontalAlignment="Left" VerticalAlignment="Top"/>
            <Button x:Name="btn_config" Content="init config" Canvas.Left="155" Canvas.Top="483" Height="57" Width="189" FontSize="30" HorizontalAlignment="Left" VerticalAlignment="Top" Click="btn_config_Click"/>
            <Button Name="btn_autoRead" Content="auto read" Canvas.Left="372" Canvas.Top="483" Height="57" Width="189" FontSize="30" HorizontalAlignment="Left" VerticalAlignment="Top" Click="btn_autoRead_Click"/>



        </Canvas>
    </Grid>
</Page>
