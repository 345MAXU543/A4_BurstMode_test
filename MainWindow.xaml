<Window x:Class="A4_BurstMode_test.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:A4_BurstMode_test"
        mc:Ignorable="d"
        Title="MainWindow" Height="1000" Width="1600" Loaded="Window_Loaded" 
        Background="#FF23262B" WindowStyle="None" AllowsTransparency="True" BorderThickness="0.1,0.1,0.1,0.1"  >

    <!-- Main grid-->
    <Grid Margin="0" >
        <!--Top Manu-->
        <Grid Margin="0,0,0,970" >
            <Grid.Background>
                <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                    <GradientStop Color="#FF313131" Offset="1"/>
                    <GradientStop Color="#FF5F5F5F" Offset="0"/>
                </LinearGradientBrush>
            </Grid.Background>

            <Rectangle Margin="0,0,0,0"/>
            <Label Content="  A4MB SDK Test tool  " HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="20" Foreground="White">
                <Label.Background>
                    <SolidColorBrush Color="#FF1B1A1A" Opacity="0.5"/>
                </Label.Background>
            </Label>
            <Label Content="X" Margin="1556,0,0,0" RenderTransformOrigin="0.5,0.5" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Foreground="Red" FontSize="20" MouseUp="btn_exit_Click">
                <Label.Background>
                    <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                        <GradientStop Color="#FF313131"/>
                        <GradientStop Color="#FF5F5F5F" Offset="1"/>
                    </LinearGradientBrush>
                </Label.Background>
                <Label.RenderTransform>
                    <TransformGroup>
                        <ScaleTransform ScaleY="-1"/>
                        <SkewTransform/>
                        <RotateTransform/>
                        <TranslateTransform/>
                    </TransformGroup>
                </Label.RenderTransform>
            </Label>

            <Label x:Name="btn_windowMin" Content="  " Margin="1515,0,44,0" RenderTransformOrigin="0.5,0.5" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Foreground="Red" FontSize="22" VerticalAlignment="Center" Height="33" MouseUp="btn_windowMin_MouseUp">
                <Label.Background>
                    <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                        <GradientStop Color="#FF5F5F5F"/>
                        <GradientStop Color="#FF313131" Offset="1"/>
                    </LinearGradientBrush>
                </Label.Background>
            </Label>
            <Label Content="  " Margin="1527,0,49,11" RenderTransformOrigin="0.5,0.5" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Background="#FFEC2525" Foreground="Red" FontSize="22" VerticalAlignment="Bottom" Height="2" MouseUp="btn_windowMin_MouseUp"/>


        </Grid>

        

        <!--Main content-->
        <Grid Margin="64,104,0,0">
            <Button Content="Button" HorizontalAlignment="Left" Margin="825,291,0,0" VerticalAlignment="Top" Height="93" Width="228"/>
            <Button Content="Button" HorizontalAlignment="Left" Margin="1186,357,0,0" VerticalAlignment="Top" Height="78" Width="140"/>
            <Button Content="Button" HorizontalAlignment="Left" Margin="432,401,0,0" VerticalAlignment="Top" Height="124" Width="252"/>

        </Grid>
        
        <!--Side Manu-->
        <Grid x:Name="grd_SideManu"  Background="#FF2D3137" Margin="0,30,1512,0" >
            <StackPanel Background="#2D2D30" Grid.Column="0">
                <Button Content="收合" Click="ToggleNav"/>
                <Button Content="首頁"/>
                <Button Content="報表"/>
            </StackPanel>
        </Grid>
        
    </Grid>
</Window>
