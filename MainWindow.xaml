<Window x:Class="A4_BurstMode_test.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:A4_BurstMode_test"
        mc:Ignorable="d"
        Title="MainWindow" Height="1000" Width="1600" Loaded="Window_Loaded" 
        Background="#FF23262B" WindowStyle="None" AllowsTransparency="True" BorderThickness="0.1,0.1,0.1,0.1"  >

    <!-- Main grid-->
    <Grid Margin="0" >
        <!--Top Manu-->
        <Grid Margin="0,0,0,970" >
            <Grid.Background>
                <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                    <GradientStop Color="#FF313131" Offset="1"/>
                    <GradientStop Color="#FF5F5F5F" Offset="0"/>
                </LinearGradientBrush>
            </Grid.Background>

            <Rectangle Margin="0,0,0,0"/>
            <Label Content="  A4MB SDK Test tool  " HorizontalAlignment="Center" VerticalAlignment="Top" FontSize="20" Foreground="White" MouseDown="Label_MouseDown" Padding="0,5,0,0">
                <Label.Background>
                    <SolidColorBrush Color="#FF1B1A1A" Opacity="0.5"/>
                </Label.Background>
            </Label>
            <Label Content="X" Margin="1556,0,0,0" RenderTransformOrigin="0.5,0.5" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Foreground="Red" FontSize="20" MouseUp="btn_exit_Click">
                <Label.Background>
                    <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                        <GradientStop Color="#FF313131"/>
                        <GradientStop Color="#FF5F5F5F" Offset="1"/>
                    </LinearGradientBrush>
                </Label.Background>
                <Label.RenderTransform>
                    <TransformGroup>
                        <ScaleTransform ScaleY="-1"/>
                        <SkewTransform/>
                        <RotateTransform/>
                        <TranslateTransform/>
                    </TransformGroup>
                </Label.RenderTransform>
            </Label>

            <Label x:Name="btn_windowMin" Content="  " Margin="1515,0,44,0" RenderTransformOrigin="0.5,0.5" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Foreground="Red" FontSize="22" VerticalAlignment="Center" Height="33" MouseUp="btn_windowMin_MouseUp">
                <Label.Background>
                    <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                        <GradientStop Color="#FF5F5F5F"/>
                        <GradientStop Color="#FF313131" Offset="1"/>
                    </LinearGradientBrush>
                </Label.Background>
            </Label>
            <Label Content="  " Margin="1527,0,49,11" RenderTransformOrigin="0.5,0.5" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Background="#FFEC2525" Foreground="Red" FontSize="22" VerticalAlignment="Bottom" Height="2" MouseUp="btn_windowMin_MouseUp"/>
            <Rectangle HorizontalAlignment="Left" Height="30" VerticalAlignment="Top" Width="1504" MouseDown="Label_MouseDown">
                <Rectangle.Fill>
                    <SolidColorBrush Color="Black" Opacity="0"/>
                </Rectangle.Fill>
                <Rectangle.Stroke>
                    <SolidColorBrush Color="Black" Opacity="0"/>
                </Rectangle.Stroke>
            </Rectangle>

        </Grid>

        <!--Main content-->
        <Grid x:Name="grd_mainContent" Margin="100,30,0,0">
            <Frame x:Name="Frame_mainFrame" NavigationUIVisibility="Hidden">
                <Frame.RenderTransform>
                    <TranslateTransform x:Name="frameTransform" X="0"/>
                </Frame.RenderTransform>
            </Frame>
            <Rectangle x:Name="rectOverlay"
         Fill="Black"
         Opacity="0"
         IsHitTestVisible="False"/>
        </Grid>

        <!--Side Manu-->
        <Grid x:Name="grd_SideManu"  Background="#FF2D3137" Margin="0,30,1500,0" MouseEnter="grd_SideManu_MouseEnter_1" MouseLeave="grd_SideManu_MouseLeave" >
            <StackPanel Background="#2D2D30" Grid.Column="0">


                <Button x:Name="img_SIdeManu_btn01" Height="87" Width="300" Cursor="Hand" Click="img_SIdeManu_btn_Click" Tag="1" Background="#FFB4D8E4" >
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Image Source="/CPU_Icon.png" Width="70" Height="70" Margin="-60,0,0,0"/>
                        <TextBlock Text="CPU操作" VerticalAlignment="Center" Foreground="#FF07045F" FontSize="30" Margin="15,0,0,0"/>
                    </StackPanel>
                </Button>

                <Button x:Name="img_SIdeManu_btn02" Height="87" Width="300" Cursor="Hand" Click="img_SIdeManu_btn_Click" Tag="2" >
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Image Source="/HandWheel_Icon.png"  Width="70" Height="70" Margin="-60,0,0,0"/>
                        <TextBlock Text="ENC操作" VerticalAlignment="Center" Foreground="#FF07045F" FontSize="30" Margin="15,0,0,0"/>
                    </StackPanel>
                </Button>

                <Button x:Name="img_SIdeManu_btn03" Height="87" Width="300" Cursor="Hand" Click="img_SIdeManu_btn_Click" Tag="3" >
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Image Source="/LoadCell_Icon.png"  Width="70" Height="70" Margin="-60,0,0,0"/>
                        <TextBlock Text="L.C.  操作" VerticalAlignment="Center" Foreground="#FF07045F" FontSize="30" Margin="15,0,0,0"/>
                    </StackPanel>
                </Button>

                <Button x:Name="img_SIdeManu_btn04" Height="87" Width="300" Cursor="Hand" Click="img_SIdeManu_btn_Click" Tag="4" >
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Image Source="/RAM_Icon.png"  Width="70" Height="70" Margin="-25,0,0,0"/>
                        <TextBlock Text="PROM 操作" VerticalAlignment="Center" Foreground="#FF07045F" FontSize="30" Margin="15,0,0,0"/>
                    </StackPanel>
                </Button>


            </StackPanel>
        </Grid>

    </Grid>
</Window>
